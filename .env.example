# =====================================================================
# J.A.R.V.I.S. Mark I - Environment Configuration
# Copy this file to '.env' and fill in your details.
# =====================================================================

# AI provider choice: 'gemini', 'openai', or 'antigravity'
AI_PROVIDER=antigravity

# --- Google Gemini Settings ---
# Generate your API Key at: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL_CHEAP=gemini-3.1-flash-lite
GEMINI_MODEL_EXPENSIVE=gemini-3.5-flash

# --- OpenAI Settings ---
# Generate your API Key at: https://platform.openai.com/
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL_CHEAP=gpt-4o-mini
OPENAI_MODEL_EXPENSIVE=gpt-4o

# --- Antigravity CLI Settings ---
ANTIGRAVITY_MODEL_CHEAP=Gemini 3.5 Flash (Low)
ANTIGRAVITY_MODEL_EXPENSIVE=Gemini 3.5 Flash (High)

# --- Network Settings ---
# URL where the backend FastAPI server is listening
API_URL=http://localhost:8000
